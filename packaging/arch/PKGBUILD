# Maintainer: community — bump pkgver/pkgrel to match release tag.
# After a tag exists, replace sha256sums with output of: curl -sL URL | sha256sum
# (or run `updpkgsums` in this directory). SKIP is valid for local iteration only.
pkgname=cantrik
pkgver=0.1.0
pkgrel=1
pkgdesc="Open-source AI CLI agent (Rust)"
arch=('x86_64' 'aarch64')
url="https://github.com/sangkan-dev/cantrik"
license=('MIT')
depends=('gcc-libs')
makedepends=('cargo' 'protobuf')
source=("$pkgname-$pkgver.tar.gz::https://github.com/sangkan-dev/cantrik/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  export PROTOC=/usr/bin/protoc
  cargo fetch --locked
}

build() {
  cd "$pkgname-$pkgver"
  export PROTOC=/usr/bin/protoc
  cargo build --release --locked -p cantrik-cli
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 target/release/cantrik "$pkgdir/usr/bin/cantrik"
}
